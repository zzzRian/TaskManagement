<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@ViewData["Title"] - Task Management</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />
<link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-kanban"></i> TaskMgr</a>
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav"><span class="navbar-toggler-icon"></span></button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        @if (User.IsInRole("Admin")) {
          <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index">Usuarios</a></li>
          <li class="nav-item"><a class="nav-link" asp-controller="Roles" asp-action="Index">Roles</a></li>
        }
        <li class="nav-item"><a class="nav-link" asp-controller="Projects" asp-action="Index">Proyectos</a></li>
        <li class="nav-item"><a class="nav-link" asp-controller="Tasks" asp-action="Index">Tareas</a></li>
        <li class="nav-item"><a class="nav-link" asp-controller="Kanban" asp-action="Index">Kanban</a></li>
        <li class="nav-item"><a class="nav-link" asp-controller="Calendar" asp-action="Index">Calendario</a></li>
        <li class="nav-item"><a class="nav-link" asp-controller="Reports" asp-action="Index">Reportes</a></li>
        @if (User.IsInRole("Admin")) {
          <li class="nav-item"><a class="nav-link" asp-controller="Audit" asp-action="Index">Auditoría</a></li>
        }
      </ul>
      <ul class="navbar-nav">
        <li class="nav-item"><a class="nav-link" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-circle"></i> @User.Identity!.Name</a></li>
        <li class="nav-item">
          <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link nav-link"><i class="bi bi-box-arrow-right"></i> Salir</button>
          </form>
        </li>
      </ul>
    </div>
  </div>
</nav>
}
<main class="container-fluid py-4">
  @RenderBody()
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
<script src="~/js/site.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
