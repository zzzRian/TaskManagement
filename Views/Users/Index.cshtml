@model IEnumerable<ApplicationUser>
@{ ViewData["Title"]="Usuarios"; }
<div class="d-flex justify-content-between mb-3"><h2>Usuarios</h2><a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus"></i> Nuevo</a></div>
<form method="get" class="mb-3"><div class="input-group" style="max-width:400px"><input name="q" value="@ViewBag.Q" class="form-control" placeholder="Buscar..."/><button class="btn btn-outline-secondary">Buscar</button></div></form>
<table class="table table-hover bg-white"><thead><tr><th>Nombre</th><th>Email</th><th>Estado</th><th></th></tr></thead><tbody>
@foreach (var u in Model) {
<tr><td>@u.FullName</td><td>@u.Email</td>
<td>@(u.IsActive ? "<span class='badge bg-success'>Activo</span>" : "<span class='badge bg-secondary'>Inactivo</span>")</td>
<td class="text-end">
<a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
<form asp-action="Toggle" asp-route-id="@u.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-warning">Toggle</button></form>
<form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminar?')">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Eliminar</button></form>
</td></tr>
}
</tbody></table>
