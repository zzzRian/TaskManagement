@model IEnumerable<ApplicationRole>
<div class="d-flex justify-content-between mb-3"><h2>Roles</h2><a asp-action="Create" class="btn btn-primary">Nuevo</a></div>
<table class="table bg-white"><thead><tr><th>Nombre</th><th>Descripción</th><th></th></tr></thead><tbody>
@foreach (var r in Model) {
<tr><td>@r.Name</td><td>@r.Description</td><td class="text-end">
<a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">Editar</a>
<form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminar?')">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Eliminar</button></form>
</td></tr>
}
</tbody></table>
