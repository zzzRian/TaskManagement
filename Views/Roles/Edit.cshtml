@model ApplicationRole
@{ var perms = (IEnumerable<Permission>)ViewBag.Permissions; var assigned = Model.RolePermissions?.Select(rp=>rp.PermissionId).ToHashSet() ?? new HashSet<int>(); }
<h2>Editar Rol</h2>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="card p-3">@Html.AntiForgeryToken()
<div class="mb-3"><label>Nombre</label><input name="name" value="@Model.Name" class="form-control"/></div>
<div class="mb-3"><label>Descripción</label><input name="description" value="@Model.Description" class="form-control"/></div>
<h6>Permisos</h6>
<div class="row">
@foreach (var p in perms) {
<div class="col-md-4 form-check"><input class="form-check-input" type="checkbox" name="permissionIds" value="@p.Id" @(assigned.Contains(p.Id)?"checked":"")/><label class="form-check-label">@p.Name <small class="text-muted">(@p.Module)</small></label></div>
}
</div>
<button class="btn btn-primary mt-3">Guardar</button>
</form>
