@model ProjectViewModel
<h2>Editar Proyecto</h2>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="card p-3" style="max-width:700px">@Html.AntiForgeryToken()
<div class="mb-3"><label>Nombre</label><input asp-for="Name" class="form-control"/></div>
<div class="mb-3"><label>Descripción</label><textarea asp-for="Description" class="form-control"></textarea></div>
<div class="row">
<div class="col-md-6 mb-3"><label>Inicio</label><input asp-for="StartDate" type="date" class="form-control"/></div>
<div class="col-md-6 mb-3"><label>Fin</label><input asp-for="EndDate" type="date" class="form-control"/></div>
</div>
<div class="mb-3"><label>Estado</label><select asp-for="Status" class="form-select">
@foreach (var s in Enum.GetValues<ProjectStatus>()) {<option value="@((int)s)" selected="@(Model.Status==s)">@s</option>}
</select></div>
<button class="btn btn-primary">Guardar</button>
</form>
