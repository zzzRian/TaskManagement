@model IEnumerable<Project>
<div class="d-flex justify-content-between mb-3"><h2>Proyectos</h2>
@if (User.IsInRole("Admin")) { <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus"></i> Nuevo</a> }
</div>
<div class="row g-3">
@foreach (var p in Model) {
<div class="col-md-4"><div class="card p-3 h-100">
<div class="d-flex justify-content-between"><h5>@p.Name</h5><span class="badge bg-info">@p.Status</span></div>
<p class="text-muted small">@p.Description</p>
<div class="small">@p.StartDate.ToShortDateString() → @p.EndDate.ToShortDateString()</div>
<div class="small text-muted">Tareas: @p.Tasks.Count · Miembros: @p.Members.Count</div>
<div class="mt-2"><a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Ver</a>
@if (User.IsInRole("Admin")) {
<a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
<form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Eliminar?')">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">X</button></form>
}
</div>
</div></div>
}
</div>
